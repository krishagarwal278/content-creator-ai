# Videaa frontend — copy to .env and fill in values. Never commit .env.

# Backend API (required for video/slideshow/voice APIs)
# Local: backend running on this machine
VITE_BACKEND_URL=http://localhost:4000
# Production (e.g. Vercel): set in your host's env to the Railway backend URL (no trailing slash)
# VITE_BACKEND_URL=https://YOUR-RAILWAY-APP.up.railway.app

# Supabase (auth + DB)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: third-party API keys if used by frontend
# PEXELS_API_KEY=
# OPENAI_API_KEY=

# Backend (Railway) must set CORS_ORIGIN so this frontend can call it, e.g.:
# https://videaa.com,https://www.videaa.com,http://localhost:8081
